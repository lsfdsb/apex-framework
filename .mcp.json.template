{
  "mcpServers": {
    "// MCP (Model Context Protocol) servers extend Claude Code with external tools.": "",
    "// Copy this file to .mcp.json and configure the servers you need.": "",
    "// Docs: https://docs.anthropic.com/en/docs/claude-code/mcp-servers": "",

    "github": {
      "// Provides GitHub API access (issues, PRs, repos) without needing gh CLI": "",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },

    "supabase": {
      "// Supabase MCP — database access, migrations, RLS, and schema management": "",
      "// Install: claude mcp add supabase -- npx -y @supabase/mcp-server-supabase@latest": "",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--access-token", "${SUPABASE_ACCESS_TOKEN}"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },

    "postgres": {
      "// Direct PostgreSQL access — use if you need raw SQL outside Supabase": "",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL}"]
    },

    "filesystem": {
      "// Scoped file access — useful for restricting Claude to specific directories": "",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./src", "./docs"]
    },

    "sentry": {
      "// Error monitoring — query Sentry issues and events directly": "",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sentry"],
      "env": {
        "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}",
        "SENTRY_ORG": "your-org",
        "SENTRY_PROJECT": "your-project"
      }
    },

    "// ── MCP Elicitation Gate Server (Claude Code v2.1.76+) ──────────────────": "",
    "// Replaces text-based approval gates with structured forms. Supports PRD,": "",
    "// architecture, and ship (merge) gates. Build the server at:": "",
    "//   ./mcp-servers/apex-gates/  (see docs/mcp-elicitation-gates.md)": "",
    "// Then uncomment the entry below and run: claude mcp add apex-gates": "",
    "//": "",
    "// \"apex-gates\": {": "",
    "//   \"command\": \"node\",": "",
    "//   \"args\": [\"./mcp-servers/apex-gates/dist/index.js\"],": "",
    "//   \"env\": {}": "",
    "// }": ""
  }
}

#!/bin/bash
# APEX Framework — Git Commit Message Hook
# Validates conventional commit format with visual feedback.
#
# Install: cp this file to .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg
# by Bueno & Claude · São Paulo, 2026

# ── Source color library ──
SCRIPT_DIR="$(cd "$(dirname "$0")/../.." 2>/dev/null && pwd)/.claude/scripts"
if [ -f "$SCRIPT_DIR/apex-colors.sh" ]; then
  source "$SCRIPT_DIR/apex-colors.sh"
fi

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits
if echo "$COMMIT_MSG" | grep -qE '^Merge'; then
  exit 0
fi

# Validate format: type(scope): description
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|refactor|test|perf|security|chore)(\([a-z0-9._-]+\))?: .+'; then
  echo ""
  if [ "$APEX_COLORS" = true ]; then
    printf "  ${ERR}Invalid commit message format${RST}\n\n"
    printf "  ${STEEL}Required${RST}  type(scope): description\n"
    printf "  ${STEEL}Types${RST}     feat fix docs refactor test perf security chore\n"
    printf "  ${STEEL}Example${RST}   ${OK}feat(auth): add OAuth login with Google${RST}\n\n"
    printf "  ${STEEL}Got${RST}       ${ERR}%s${RST}\n" "$COMMIT_MSG"
  else
    echo "  Invalid commit message format"
    echo ""
    echo "  Required  type(scope): description"
    echo "  Types     feat fix docs refactor test perf security chore"
    echo "  Example   feat(auth): add OAuth login with Google"
    echo ""
    echo "  Got       $COMMIT_MSG"
  fi
  echo ""
  exit 1
fi

# Check length
if [ ${#COMMIT_MSG} -gt 72 ]; then
  echo ""
  if [ "$APEX_COLORS" = true ]; then
    printf "  ${WARN}Subject too long${RST} ${STEEL}(${#COMMIT_MSG} chars, max 72)${RST}\n"
    printf "  ${STEEL}Use the body for details.${RST}\n"
  else
    echo "  Subject too long (${#COMMIT_MSG} chars, max 72)"
    echo "  Use the body for details."
  fi
  echo ""
  exit 1
fi

if [ "$APEX_COLORS" = true ]; then
  printf "  ${OK}✓${RST} ${STEEL}%s${RST}\n" "$COMMIT_MSG"
fi

exit 0

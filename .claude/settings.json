{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Skill",
      "Bash(pnpm run *)",
      "Bash(pnpm dev *)",
      "Bash(pnpm build *)",
      "Bash(pnpm add *)",
      "Bash(pnpm install *)",
      "Bash(pnpm preview)",
      "Bash(pnpm lint)",
      "Bash(pnpm format)",
      "Bash(npm run *)",
      "Bash(npm view *)",
      "Bash(npm audit *)",
      "Bash(npx vitest *)",
      "Bash(npx playwright *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx drizzle-kit *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git worktree *)",
      "Bash(git tag *)",
      "Bash(git push *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(cat > ~/.claude/apex-preferences.json *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push * -f)",
      "Bash(git push * --force)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.*.local)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.claude/settings.json)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "APEX_FRAMEWORK_REPO": "/Users/lsfdsb/projects/apex-framework"
  },
  "sandbox": {
    "filesystem": {
      "denyWrite": [
        "//etc/**",
        "//usr/**",
        "//System/**",
        "~/.ssh/**",
        "~/.aws/**",
        "~/.gnupg/**",
        "~/.claude/settings.json"
      ],
      "denyRead": [
        "~/.ssh/id_*",
        "~/.aws/credentials",
        "~/.gnupg/private-keys-v1.d/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "api.anthropic.com",
        "*.supabase.co",
        "*.vercel.app",
        "*.sentry.io"
      ]
    }
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".next",
      ".cache",
      "dist",
      ".turbo"
    ]
  },
  "outputStyle": "APEX Educational",
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/apex-statusline.sh",
    "timeout": 5
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/auto-update.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/session-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/dev-server.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/block-dangerous-commands.sh",
            "timeout": 5,
            "statusMessage": "Checking command safety..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/protect-files.sh",
            "timeout": 5,
            "statusMessage": "Checking file protection..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/enforce-workflow.sh",
            "timeout": 5,
            "statusMessage": "Verifying workflow compliance..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/scan-security-patterns.sh",
            "timeout": 5,
            "statusMessage": "Scanning for security patterns..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/auto-changelog.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-cleanup.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/handle-failure.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/stop-gate.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/dev-monitor.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"📋 Task completed — check TaskList for next available work or handoff.\"}'",
            "timeout": 2
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"suppressOutput\":true}'",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/session-learner.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/session-cleanup.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"⚔️ APEX: Settings changed. Hooks and permissions reloaded.\"}'",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
